<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Potinho do GOAT | O Brabo</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Satisfy&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    
    <style>
        :root {
            --primary: #E96A8D;
            --secondary: #fbb1bd;
            --dark: #5C3A2E;
            --bg-base: #FFF4E8;
            --glass: rgba(255, 255, 255, 0.9);
            --gradient: linear-gradient(135deg, #E96A8D 0%, #ffb7b2 100%);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg-base);
            background-image: radial-gradient(#f3e5d8 1px, transparent 1px);
            background-size: 30px 30px;
            color: var(--dark);
            overflow-x: hidden;
            transition: 0.5s;
        }

        header {
            background: var(--gradient);
            padding: 4rem 1rem;
            text-align: center;
            color: white;
            clip-path: polygon(0 0, 100% 0, 100% 85%, 0% 100%);
            animation: slideDown 0.8s ease-out;
        }

        header h1 { 
            font-family: 'Satisfy', cursive; 
            font-size: clamp(3rem, 10vw, 5rem);
            animation: glow 2s infinite;
        }

        @keyframes glow {
            0%, 100% { text-shadow: 0 0 10px #fff; }
            50% { text-shadow: 0 0 20px var(--primary), 0 0 30px var(--primary); }
        }

        .container { 
            max-width: 1100px; 
            margin: 0 auto; 
            padding: 1.5rem; 
            width: 100%;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: white;
            border-radius: 25px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(92, 58, 46, 0.1);
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            border: 2px solid transparent;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Estilo das Imagens dos Potes */
        .card-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 15px;
            margin-bottom: 15px;
        }

        @media (hover: hover) {
            .card:hover { 
                transform: scale(1.05) rotate(2deg); 
                border-color: var(--primary);
                box-shadow: 0 20px 40px rgba(233, 106, 141, 0.2);
            }
        }

        .order-section {
            background: white;
            margin-top: 3rem;
            padding: 2rem;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(92, 58, 46, 0.1);
        }

        .input-row { 
            display: flex; 
            flex-direction: row; 
            gap: 1rem; 
            margin-bottom: 1.2rem; 
        }

        @media (max-width: 600px) {
            .input-row { flex-direction: column; }
            header { padding: 3rem 1rem; }
            .order-section { padding: 1.5rem; }
            .container { padding: 1rem; }
            input, select { font-size: 16px !important; }
        }

        input, select { 
            flex: 1; 
            padding: 1rem; 
            border: 2px solid #f3e5d8; 
            border-radius: 15px; 
            font-family: 'Poppins', sans-serif;
            font-size: 1rem;
            width: 100%;
            color: var(--dark);
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .btn-order {
            background: var(--gradient);
            font-size: 1.1rem;
            letter-spacing: 1px;
            border: none; 
            color: white; 
            padding: 1.2rem; 
            border-radius: 20px; 
            cursor: pointer; 
            width: 100%; 
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-order:hover {
            filter: brightness(1.1);
            transform: translateY(-2px);
        }

        footer { text-align: center; padding: 2rem; font-size: 0.9rem; opacity: 0.8; color: var(--dark); }
    </style>
</head>
<body>

<header>
    <h1>Potinho do GOAT</h1>
    <p>A verdadeira liberdade vem da escolha.</p>
</header>

<div class="container">
    <div class="menu-grid">
        <div class="card" onclick="autoSelect('Brigadeiro')">
            <img src="1000089367.png" alt="Pote de Brigadeiro" class="card-img">
            <div>
                <h3>🍫 Brigadeiro</h3>
                <p>Feito pelo Martelo, o programador dessa beleza aqui.</p>
                <br>
                <strong style="color: var(--primary); font-size: 1.3rem;">R$ 10,00</strong>
            </div>
        </div>

        <div class="card" onclick="autoSelect('Ninho')">
            <img src="1000089368.png" alt="Pote de Ninho" class="card-img">
            <div>
                <h3>🥛 Ninho</h3>
                <p>Feito com o puro creme do Ninho (sem caspa, prometo!).</p>
                <br>
                <strong style="color: var(--primary); font-size: 1.3rem;">R$ 10,00</strong>
            </div>
        </div>

        <div class="card" onclick="autoSelect('Casado')">
            <img src="1000089369.png" alt="Pote Casado" class="card-img">
            <div>
                <h3>💍 Casado</h3>
                <p>Feito com o melhor dos dois mundos. Vai encarar?</p>
                <br>
                <strong style="color: var(--primary); font-size: 1.3rem;">R$ 10,00</strong>
            </div>
        </div>
    </div>

    <div class="order-section" id="encomenda">
        <h2 style="text-align: center; margin-bottom: 1.5rem; color: var(--dark);">Faça seu pedido</h2>
        <form id="cakeForm">
            <div class="input-row">
                <input type="text" id="nome" placeholder="Seu Nome" required>
                <input type="text" id="turma" placeholder="Sua Sala (Ex: 3ºA)" required>
            </div>
            
            <select id="sabor" style="width: 100%; margin-bottom: 1.5rem;" required>
                <option value="">Escolha entre os três cavalheiros</option>
                <option value="Brigadeiro">Brigadeiro</option>
                <option value="Ninho">Ninho</option>
                <option value="Casado">Casado</option>
            </select>

            <button type="submit" id="submitBtn" class="btn-order">RESERVAR MEU POTE</button>
        </form>
    </div>
</div>

<footer>
    <p>&copy; O cara tá virado há dois dias. Valoriza o trampo! 🔥</p>
</footer>

<script>
    function autoSelect(sabor) {
        document.getElementById('sabor').value = sabor;
        document.getElementById('encomenda').scrollIntoView({ behavior: 'smooth' });
    }

    document.getElementById('cakeForm').addEventListener('submit', function(e) {
        e.preventDefault();
        confetti({ 
            particleCount: 150, 
            spread: 70, 
            origin: { y: 0.8 },
            colors: ['#E96A8D', '#FFF4E8', '#5C3A2E']
        });
        
        const btn = document.getElementById('submitBtn');
        const originalText = btn.innerText;
        btn.innerText = "RESERVA FEITA!";
        btn.style.background = "#2ecc71";
        
        setTimeout(() => {
            alert("A tropa está a caminho. Prepare o PIX!");
            this.reset();
            btn.innerText = originalText;
            btn.style.background = "var(--gradient)";
        }, 800);
    });
</script>
</body>
</html>
